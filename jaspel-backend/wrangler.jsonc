{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jaspel-backend",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-31",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "jaspel-db",
      "database_id": "local-db",
      "migrations_dir": "drizzle"
    }
  ],
